# ─────────────────────────────────────────────────────────────
#  MailSender Pro — Ortam Değişkenleri (.env.example)
#  Bu dosyayı kopyalayıp .env olarak kaydedin:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Veritabanı ────────────────────────────────────────────────
DB_HOST='localhost'
DB_PORT='3306'
DB_USER='root'
DB_PASSWORD='102030'
DB_NAME='aws_mail_sender_pro_v2'
SECRET_KEY='I3CnBPJtnW3Hwv0rJt4yLrccKJE3Ss87B9sKqbRYuiY='

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
UNSUB_APP_URL=https://unsub.bidanismanlik.com
UNSUB_API_KEY=I3CnBPJtnW3Hwv0rJt4yLrccKJE3Ss87B9sKqbRYuiY
# DB_SSL=true → MySQL bağlantısı TLS ile şifrelenir
# AWS RDS veya harici MySQL kullanıyorsanız true yapın
DB_SSL=false

# ── Şifreleme ─────────────────────────────────────────────────
# SMTP/AWS şifrelerini DB'de şifrelemek için kullanılır
# Üretmek için: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ÖNEMLİ: Bu değeri asla paylaşmayın, yedekleyin, Git'e koymayın!
SECRET_KEY='I3CnBPJtnW3Hwv0rJt4yLrccKJE3Ss87B9sKqbRYuiY='

# ── Uygulama ──────────────────────────────────────────────────
# Unsubscribe linklerinde kullanılır — domain adresiniz
APP_BASE_URL=https://bidanismanlik.com

# FORCE_HTTPS=true → HTTP isteklerini HTTPS'e yönlendirir
# Nginx/HTTPS kurulumu tamamlandıktan sonra true yapın
FORCE_HTTPS=false

# ── (Opsiyonel) Uygulama Şifresi ─────────────────────────────
# Uygulamaya erişimi parola ile korumak isterseniz doldurun
# Boş bırakırsanız koruma devre dışı kalır
# APP_ACCESS_PASSWORD=
